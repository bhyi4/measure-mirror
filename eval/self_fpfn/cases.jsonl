{"id":"bf02","probe":"baseline_fairness","label":"defective","bucket":"core","args":{"claimed":0.705,"baseline":0.70},"note":"tied within margin 0.01"}
{"id":"bf03","probe":"baseline_fairness","label":"clean","bucket":"core","args":{"claimed":0.80,"baseline":0.60},"note":"genuine 20pt beat"}
